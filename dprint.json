{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "lineWidth": 100,
  "useTabs": false,
  "indentWidth": 2,
  "newLineKind": "lf",
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.96.1.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.22.1.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.3.wasm"
  ],
  "includes": [
    "**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,toml,yml,yaml,html}"
  ],
  "excludes": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.next/**",
    "**/.source/**",
    "**/coverage/**",
    "**/next-env.d.ts",
    "pnpm-lock.yaml",
    "**/.changeset/pre.json",
    "benchmark/apps/app-panda/styled-system/**"
  ],
  "typescript": {
    "lineWidth": 120,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": "always",
    "quoteStyle": "preferSingle",
    "trailingCommas": "onlyMultiLine",
    "arrowFunction.useParentheses": "force",
    "operatorPosition": "nextLine",
    "binaryExpression.operatorPosition": "sameLine",
    "conditionalExpression.operatorPosition": "nextLine",
    "conditionalType.operatorPosition": "nextLine",
    "jsx.bracketPosition": "nextLine",
    "jsx.multiLineParens": "prefer",
    "jsx.forceNewLinesSurroundingContent": false
  },
  "json": {
    "indentWidth": 2
  },
  "markdown": {
    "textWrap": "maintain"
  }
}
