{
  "name": "@example/bundler-esbuild",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clear": "rm -rf dist",
    "build": "node esbuild.config.mjs",
    "build:runtime": "FLUENTIC_STYLE_MODE=runtime node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "dev:runtime": "FLUENTIC_STYLE_MODE=runtime node esbuild.config.mjs --watch",
    "serve": "npx serve dist -l 4177"
  },
  "dependencies": {
    "@example/bundler-shared": "workspace:*",
    "@fluentic/style": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  }
}
