{
  "name": "@example/bundler-webpack",
  "private": true,
  "version": "0.0.1-beta.0",
  "type": "module",
  "scripts": {
    "clear": "rm -rf dist node_modules/.cache",
    "dev": "webpack serve --mode development",
    "dev:runtime": "FLUENTIC_STYLE_MODE=runtime webpack serve --mode development",
    "dev:sourcemap.sidecarServer": "SOURCEMAP=sidecarServer webpack serve --mode development",
    "dev:sourcemap.sourceContent": "SOURCEMAP=sourceContent webpack serve --mode development",
    "build": "webpack --mode production",
    "build:runtime": "FLUENTIC_STYLE_MODE=runtime webpack --mode production",
    "serve": "npx serve dist -l 4174"
  },
  "dependencies": {
    "@example/bundler-shared": "workspace:*",
    "@fluentic/style": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.5",
    "mini-css-extract-plugin": "^2.9.4",
    "style-loader": "^4.0.0",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}
