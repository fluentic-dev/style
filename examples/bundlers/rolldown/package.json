{
  "name": "@example/bundler-rolldown",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clear": "rm -rf dist",
    "build": "rolldown -c",
    "build:runtime": "FLUENTIC_STYLE_MODE=runtime rolldown -c",
    "dev": "rolldown -c -w",
    "dev:runtime": "FLUENTIC_STYLE_MODE=runtime rolldown -c -w",
    "serve": "npx serve dist -l 4176"
  },
  "dependencies": {
    "@example/bundler-shared": "workspace:*",
    "@fluentic/style": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "rolldown": "^1.0.3",
    "typescript": "^5.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
