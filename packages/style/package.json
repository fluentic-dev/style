    "./entry/dev/jsx-dev-runtime": {
      "types": "./entry/dev/jsx_dev_runtime.ts",
      "import": "./dist/entry/dev/jsx-dev-runtime.js"
    },
    "./entry/prod/jsx-runtime": {
      "types": "./entry/prod/jsx_runtime.ts",
      "import": "./dist/entry/prod/jsx-runtime.js"
    },
    "./entry/prod/jsx-dev-runtime": {
      "types": "./entry/prod/jsx_dev_runtime.ts",
      "import": "./dist/entry/prod/jsx-dev-runtime.js"
    },
    "./entry/rsc-dev/jsx-runtime": {
      "types": "./entry/rsc_dev/jsx_runtime.ts",
      "import": "./dist/entry/rsc-dev/jsx-runtime.js"
    },
    "./entry/rsc-dev/jsx-dev-runtime": {
      "types": "./entry/rsc_dev/jsx_dev_runtime.ts",
      "import": "./dist/entry/rsc-dev/jsx-dev-runtime.js"
