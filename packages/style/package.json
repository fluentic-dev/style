  "files": [
    "README.md",
    "dist",
    "atomic",
    "builder",
    "config",
    "compiler",
    "dev",
    "jsx",
    "plugin",
    "entry",
    "runtime",
    "selector",
    "server.ts",
    "sheet",
    "atRule",
    "css",
    "style",
    "utils",
    "index.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "report:bundle": "node ./scripts/report-bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx ./tests/run-tests.ts"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "0.3.31",
    "css-what": "8.0.0",
    "csstype": "3.2.3",
    "oxc-resolver": "11.20.0",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@types/babel__core": "7.20.5",
    "@types/picomatch": "4.0.3",
    "@types/react": "19.2.14",
