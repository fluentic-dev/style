{
  "name": "@fluentic/style",
  "version": "0.1.0-beta.0",
  "description": "Type-safe styles that scale with your components.",
  "homepage": "https://fluenticstack.com/style",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fluentic-dev/style.git",
    "directory": "packages/style"
  },
  "bugs": {
    "url": "https://github.com/fluentic-dev/style/issues"
  },
  "author": {
    "name": "Fluentic",
    "email": "omnidev@fluenticstack.com",
    "url": "https://fluenticstack.com"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "react",
    "css-in-js",
    "atomic-css",
    "design-system",
    "component-library",
    "styling",
    "vite",
    "nextjs",
    "compiler"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./index.ts",
      "react-server": "./dist/server.js",
      "import": "./dist/index.js"
    },
    "./plugin/vite": {
      "types": "./plugin/bundler/vite/index.ts",
      "import": "./dist/plugin/vite/index.mjs"
    },
    "./plugin/webpack": {
      "types": "./plugin/bundler/webpack/index.ts",
      "import": "./dist/plugin/webpack/index.mjs"
    },
    "./plugin/webpack/loader": {
      "types": "./plugin/bundler/webpack/loader.ts",
      "import": "./dist/plugin/webpack/loader.mjs",
      "default": "./dist/plugin/webpack/loader.mjs"
    },
    "./plugin/rspack": {
      "types": "./plugin/bundler/rspack/index.ts",
      "import": "./dist/plugin/rspack/index.mjs"
    },
    "./plugin/farm": {
      "types": "./plugin/bundler/farm/index.ts",
      "import": "./dist/plugin/farm/index.mjs"
    },
    "./plugin/parcel": {
      "types": "./plugin/bundler/parcel/index.ts",
      "import": "./dist/plugin/parcel/index.mjs",
      "require": "./dist/plugin/parcel/index.cjs"
    },
    "./plugin/parcel/config": {
      "default": "./plugin/bundler/parcel/config.json"
    },
    "./plugin/parcel/transformer": {
      "types": "./plugin/bundler/parcel/transformer.ts",
      "import": "./dist/plugin/parcel/transformer.mjs",
      "require": "./dist/plugin/parcel/transformer.cjs",
      "default": "./dist/plugin/parcel/transformer.mjs"
    },
    "./plugin/parcel/resolver": {
      "types": "./plugin/bundler/parcel/resolver.ts",
      "import": "./dist/plugin/parcel/resolver.mjs",
      "require": "./dist/plugin/parcel/resolver.cjs",
      "default": "./dist/plugin/parcel/resolver.mjs"
    },
    "./plugin/parcel/runtime": {
      "types": "./plugin/bundler/parcel/runtime.ts",
      "import": "./dist/plugin/parcel/runtime.mjs",
      "require": "./dist/plugin/parcel/runtime.cjs",
      "default": "./dist/plugin/parcel/runtime.mjs"
    },
    "./plugin/parcel/optimizer": {
      "types": "./plugin/bundler/parcel/optimizer.ts",
      "import": "./dist/plugin/parcel/optimizer.mjs",
      "require": "./dist/plugin/parcel/optimizer.cjs",
      "default": "./dist/plugin/parcel/optimizer.mjs"
    },
    "./plugin/nextjs": {
      "types": "./plugin/nextjs/index.ts",
      "import": "./dist/plugin/nextjs/index.mjs",
      "default": "./dist/plugin/nextjs/index.mjs"
    },
    "./plugin/nextjs/loader": {
      "types": "./plugin/nextjs/loader.ts",
      "import": "./dist/plugin/nextjs/loader.mjs",
      "default": "./dist/plugin/nextjs/loader.mjs"
    },
    "./plugin/jsx/jsx-runtime": {
      "types": "./entry/prod/jsx_runtime.ts",
      "react-server": "./dist/entry/rsc-prod/jsx-runtime.js",
      "import": "./dist/entry/prod/jsx-runtime.js",
      "default": "./dist/entry/prod/jsx-runtime.js"
    },
    "./plugin/jsx/jsx-dev-runtime": {
      "types": "./entry/dev/jsx_dev_runtime.ts",
      "react-server": "./dist/entry/rsc-dev/jsx-dev-runtime.js",
      "import": "./dist/entry/dev/jsx-dev-runtime.js",
      "default": "./dist/entry/dev/jsx-dev-runtime.js"
    },
    "./config": {
      "types": "./config/index.ts",
      "import": "./dist/config/index.js"
    },
    "./compiler": {
      "types": "./compiler/index.ts",
      "import": "./dist/compiler/index.mjs"
    },
    "./selector": {
      "types": "./selector/index.ts",
      "import": "./dist/selector/index.js"
    },
    "./dev": {
      "types": "./dev/index.ts",
      "import": "./dist/dev.js"
    },
    "./dev/rsc": {
      "types": "./runtime/rsc/index.ts",
      "import": "./dist/dev/rsc.js"
    },
    "./css": {
      "types": "./css/index.ts",
      "import": "./dist/css.js"
    },
    "./utils": {
      "types": "./style/utils/index.ts",
      "import": "./dist/utils.js"
    },
    "./builder/extract": {
      "types": "./builder/extract/index.ts",
      "import": "./dist/entry/prod/extract.js"
    },
    "./server/extracted": {
      "types": "./entry/rsc_prod/server.ts",
      "import": "./dist/entry/rsc-prod.js"
    },
    "./jsx-runtime/server/extracted": {
      "types": "./entry/rsc_prod/jsx_runtime.ts",
      "import": "./dist/entry/rsc-prod/jsx-runtime.js"
    },
    "./jsx/jsx-runtime": {
      "types": "./jsx/runtime/jsx_runtime.ts",
      "react-server": null,
      "import": "./dist/jsx/jsx-runtime.js"
    },
    "./jsx/jsx-dev-runtime": {
      "types": "./jsx/runtime/jsx_dev_runtime.ts",
      "react-server": null,
      "import": "./dist/jsx/jsx-dev-runtime.js"
    },
    "./entry/dev": {
      "types": "./entry/dev/index.ts",
      "import": "./dist/entry/dev.js"
    },
    "./entry/prod": {
      "types": "./entry/prod/index.ts",
      "import": "./dist/entry/prod.js"
    },
    "./entry/rsc-dev": {
      "types": "./entry/rsc_dev/index.ts",
      "import": "./dist/entry/rsc-dev.js"
    },
    "./entry/rsc-dev/dev": {
      "types": "./runtime/rsc/index.ts",
      "import": "./dist/entry/rsc-dev/dev.js"
    },
    "./entry/rsc-prod": {
      "types": "./entry/rsc_prod/index.ts",
      "import": "./dist/entry/rsc-prod.js"
    },
    "./entry/rsc-prod/runtime": {
      "types": "./entry/rsc_prod/runtime.ts",
      "import": "./dist/entry/rsc-prod/runtime.js"
    },
    "./entry/dev/css": {
      "types": "./entry/dev/css.ts",
      "import": "./dist/entry/dev/css.js"
    },
    "./entry/prod/css": {
      "types": "./entry/prod/css.ts",
      "import": "./dist/entry/prod/css.js"
    },
    "./entry/rsc-dev/css": {
      "types": "./entry/rsc_dev/css.ts",
      "import": "./dist/entry/rsc-dev/css.js"
    },
    "./entry/rsc-prod/css": {
      "types": "./entry/rsc_prod/css.ts",
      "import": "./dist/entry/rsc-prod/css.js"
    },
    "./entry/prod/runtime": {
      "types": "./entry/prod/runtime.ts",
      "import": "./dist/entry/prod/runtime.js"
    },
    "./entry/prod/extract": {
      "types": "./entry/prod/extract.ts",
      "import": "./dist/entry/prod/extract.js"
    }
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "dist",
    "atomic",
    "builder",
    "config",
    "compiler",
    "dev",
    "jsx",
    "plugin",
    "entry",
    "runtime",
    "selector",
    "sheet",
    "atRule",
    "css",
    "style",
    "utils",
    "index.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "node ../../scripts/sync-package-readme.mjs copy",
    "postpack": "node ../../scripts/sync-package-readme.mjs clean",
    "report:bundle": "node ./scripts/report-bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx ./tests/run-tests.ts"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "0.3.31",
    "@parcel/config-default": "^2.16.1",
    "css-what": "8.0.0",
    "csstype": "3.2.3",
    "lightningcss": "^1.32.0",
    "oxc-resolver": "11.20.0",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@types/babel__core": "7.20.5",
    "@types/picomatch": "4.0.3",
    "@types/react": "19.2.14",
    "react": "19.2.0",
    "tsdown": "0.22.1",
    "tsx": "4.20.6",
    "typescript": "5.8.3",
    "vite": "8.0.16",
    "webpack": "5.107.2"
  },
  "peerDependencies": {
    "@babel/core": ">=7",
    "@farmfe/core": ">=1",
    "@parcel/plugin": ">=2",
    "@rspack/core": ">=1",
    "next": ">=15",
    "react": ">=16.14",
    "vite": ">=5",
    "webpack": ">=5"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "@farmfe/core": {
      "optional": true
    },
    "@parcel/plugin": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  }
}
