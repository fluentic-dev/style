{
  "name": "fluentic-style-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "pnpm --filter @fluentic/style build && pnpm --filter @example/* build && pnpm -r --filter @benchmark/app-* build",
    "bench": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/main bench",
    "bench:stable": "BENCH_PRESET=stable pnpm bench",
    "bench:stress": "BENCH_PRESET=stress pnpm bench",
    "bench:correctness": "pnpm --filter @benchmark/main bench:correctness",
    "bench:dynamic-values": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/main bench:dynamic-values",
    "bench:fluentic-cache": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/main bench:fluentic-cache",
    "bench:ssr-style": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/main bench:ssr-style",
    "bench:compiler": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/main bench:compiler",
    "sync:package-readme": "node scripts/sync-package-readme.mjs copy",
    "test": "pnpm --filter @fluentic/style test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && node scripts/sync-package-readme.mjs run pnpm exec changeset publish",
    "snapshot:style": "pnpm --filter @fluentic/style test && pnpm --filter @example/snapshots generate",
    "format": "DPRINT_CACHE_DIR=$PWD/.dprint-cache dprint fmt",
    "format:check": "DPRINT_CACHE_DIR=$PWD/.dprint-cache dprint check",
    "formatcheck": "pnpm run format:check",
    "typecheck": "node scripts/typecheck-workspace.mjs",
    "check": "node scripts/check-workspace.mjs",
    "lint": "oxlint .",
    "lintcheck": "pnpm run lint",
    "lint:fix": "oxlint . --fix"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "dprint": "^0.54.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "dprint",
      "esbuild",
      "sharp"
    ]
  }
}
