{
  "name": "fluentic-style-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "pnpm --filter @fluentic/style build && pnpm --filter @example/* build && pnpm -r --filter @benchmark/app-* build",
    "dev:example:basic": "pnpm --filter @fluentic/style build && pnpm --filter @example/basic dev",
    "build:example:basic": "pnpm --filter @fluentic/style build && pnpm --filter @example/basic build",
    "dev:example:vite": "pnpm --filter @fluentic/style build && pnpm --filter @example/bundler-vite dev",
    "clear:example:vite": "rm -rf packages/style/dist node_modules/.cache/fluentic-style node_modules/.vite examples/bundlers/vite/dist examples/bundlers/vite/node_modules/.cache examples/bundlers/vite/node_modules/.vite",
    "dev:example:vite:clear": "pnpm run clear:example:vite && pnpm --filter @fluentic/style build && pnpm --filter @example/bundler-vite dev:clear",
    "dev:example:webpack": "pnpm --filter @fluentic/style build && pnpm --filter @example/bundler-webpack dev",
    "clear:example:webpack": "rm -rf packages/style/dist node_modules/.cache/fluentic-style examples/bundlers/webpack/dist examples/bundlers/webpack/node_modules/.cache",
    "dev:example:webpack:clear": "pnpm run clear:example:webpack && pnpm --filter @fluentic/style build && pnpm --filter @example/bundler-webpack dev:clear",
    "dev:example:rollup": "pnpm --filter @fluentic/style build && pnpm --filter @example/bundler-rollup dev",
    "dev:example:rspack": "pnpm --filter @fluentic/style build && pnpm --filter @example/bundler-rspack dev",
    "dev:example:rolldown": "pnpm --filter @fluentic/style build && pnpm --filter @example/bundler-rolldown dev",
    "dev:example:esbuild": "pnpm --filter @fluentic/style build && pnpm --filter @example/bundler-esbuild dev",
    "dev:example:farm": "pnpm --filter @fluentic/style build && pnpm --filter @example/bundler-farm dev",
    "dev:bench:style": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-fluentic-style dev:plugin",
    "dev:bench:style:plugin": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-fluentic-style dev:plugin",
    "dev:bench:style:runtime": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-fluentic-runtime dev",
    "prod:bench:style:plugin": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-fluentic-style prod:plugin",
    "dev:bench:emotion": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-emotion dev",
    "dev:bench:styled": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-styled-components dev",
    "dev:bench:goober": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-goober dev",
    "dev:bench:stylex": "pnpm --filter @benchmark/app-stylex dev",
    "prod:bench:stylex": "pnpm --filter @benchmark/app-stylex prod",
    "dev:bench:panda": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-panda dev",
    "dev:bench:vanilla": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-vanilla-extract dev",
    "dev:bench:cssm": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/app-css-modules dev",
    "bench": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/main bench",
    "bench:stable": "BENCH_PRESET=stable pnpm bench",
    "bench:stress": "BENCH_PRESET=stress pnpm bench",
    "bench:contract": "pnpm --filter @benchmark/main bench:contract",
    "bench:dynamic-values": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/main bench:dynamic-values",
    "bench:fluentic-cache": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/main bench:fluentic-cache",
    "bench:ssr-style": "pnpm --filter @fluentic/style build && pnpm --filter @benchmark/main bench:ssr-style",
    "test": "pnpm --filter @fluentic/style test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "snapshot:style": "pnpm --filter @fluentic/style test && pnpm --filter @example/snapshots generate",
    "format": "DPRINT_CACHE_DIR=$PWD/.dprint-cache dprint fmt",
    "format:check": "DPRINT_CACHE_DIR=$PWD/.dprint-cache dprint check",
    "formatcheck": "pnpm run format:check",
    "typecheck": "node scripts/typecheck-workspace.mjs",
    "check": "node scripts/check-workspace.mjs",
    "lint": "oxlint .",
    "lintcheck": "pnpm run lint",
    "lint:fix": "oxlint . --fix"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "dprint": "^0.54.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "dprint",
      "esbuild",
      "sharp"
    ]
  }
}
