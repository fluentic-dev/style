{
  "extends": "../../tsconfig.base.json",
  "include": [
    ".source/**/*.ts",
    "next-env.d.ts",
    "next.config.mjs",
    "source.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "Bundler",
    "paths": {
      "#playground/*": ["./src/playground/*"]
    }
  }
}
